# ─── Oracle Cloud Database 연결 설정 ─────────────────────────────────────────
# Oracle Cloud Autonomous Database (ADB) 또는 일반 Oracle DB 모두 지원.

# DB 접속 계정 정보
ORACLE_USER=admin
ORACLE_PASSWORD=YourSecurePassword123!

# ── 접속 방식 A: Wallet 기반 (Oracle Cloud ADB 권장) ─────────────────────────
# Oracle Cloud Console → Autonomous Database → DB 연결 → 지갑 다운로드
# 다운로드한 wallet.zip 파일을 backend/wallet/ 폴더에 압축 해제
ORACLE_WALLET_LOCATION=./wallet
# 지갑 생성 시 설정한 비밀번호 (없으면 빈 값)
ORACLE_WALLET_PASSWORD=

# tnsnames.ora 에 정의된 서비스 별칭
# 예: mydb_high, mydb_medium, mydb_low (성능 프로파일에 따라 선택)
ORACLE_DSN=mydb_medium

# ── 접속 방식 B: 직접 TCP (온프레미스 / VM Oracle DB) ────────────────────────
# ORACLE_DSN=myhost.example.com:1521/ORCL
# 직접 접속 시에는 ORACLE_WALLET_LOCATION / ORACLE_WALLET_PASSWORD 비워두기

# ─── 커넥션 풀 설정 ───────────────────────────────────────────────────────────
ORACLE_POOL_MIN=2     # 최소 유지 연결 수
ORACLE_POOL_MAX=10    # 최대 연결 수
ORACLE_POOL_INCREMENT=1

# ─── 대체 가격 API 키 (선택) ──────────────────────────────────────────────────
# Alpha Vantage 무료 키 (5 req/min) - https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# ─── 앱 서버 설정 ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True
FRONTEND_URL=http://localhost:5173
